DEFAULT_FALLBACK = [
    "Все нейросети сейчас заняты. Попробуй переформулировать вопрос или повтори чуть позже.",
    "Я тебя слышу, но облачные модели не отвечают. Скажи иначе — я постараюсь помочь сам.",
    "Извини, не понял. Можешь задать вопрос проще?",
]


def chatbot_fallback(prompt: str) -> str:
    """Простейший rule-based чат-бот на готовых ответах."""
    text = prompt.lower().strip()
    for keywords, answers in FALLBACK_RULES:
        for kw in keywords:
            if re.search(rf"\b{re.escape(kw)}\b", text):
                return random.choice(answers)
    return random.choice(DEFAULT_FALLBACK)


# =====================================================================
#                       ОСНОВНАЯ ЛОГИКА БОТА
# =====================================================================

class MultiAIBot:
    """Бот, опрашивающий список провайдеров по очереди."""

    def __init__(self, providers=PROVIDERS, retries: int = 1, verbose: bool = True):
        self.providers = providers
        self.retries = retries
        self.verbose = verbose

    def _log(self, msg: str) -> None:
        if self.verbose:
            print(msg)

    def ask(self, prompt: str) -> str:
        for name, func in self.providers:
            for attempt in range(1, self.retries + 1):
                try:
                    self._log(f"  → пробую {name} (попытка {attempt})...")
                    answer = func(prompt)
                    if answer and answer.strip():
                        self._log(f"  ✓ ответил {name}")
                        return answer.strip()
                except Exception as e:
                    self._log(f"  ✗ {name} недоступен: {e}")
                    continue

        self._log("  ! все нейросети заняты — включаю встроенный чат-бот")
        return chatbot_fallback(prompt)


# =====================================================================
#                       СОХРАНЕНИЕ В ФАЙЛ
# =====================================================================

LOG_FILE = "chat_log.txt"


def save_to_file(prompt: str, answer: str, path: str = LOG_FILE) -> None:
    """Дописывает диалог в текстовый файл."""
    with open(path, "a", encoding="utf-8") as f:
        f.write(f"[{time.strftime('%Y-%m-%d %H:%M:%S')}]\n")
        f.write(f"Вы: {prompt}\n")
        f.write(f"Бот: {answer}\n")
        f.write("-" * 60 + "\n")


# =====================================================================
#                            ИНТЕРФЕЙС
# =====================================================================

def main() -> None:
    print("=" * 60)
    print("  Мульти-нейросетевой бот")
    print("  Подключено провайдеров:", len(PROVIDERS))
    print("  Команды: /выход — закончить, /очистить — стереть лог")
    print("=" * 60)

    bot = MultiAIBot()

    while True:
        try:
            prompt = input("\nВы: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nДо встречи!")
            break

        if not prompt:
            continue
        if prompt.lower() in {"/выход", "/exit", "/quit"}:
            print("До встречи!")
            break
        if prompt.lower() in {"/очистить", "/clear"}:
            open(LOG_FILE, "w", encoding="utf-8").close()
            print("Лог очищен.")
            continue

        answer = bot.ask(prompt)
        print(f"\nБот: {answer}")
        save_to_file(prompt, answer)


if __name__ == "__main__":
    main()
